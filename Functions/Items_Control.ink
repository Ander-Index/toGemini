LIST List__Items = 不明生物的尸体,枯树的碎片
////////////////////////////////
////////////////////////////////
////////////////////////////////
////////////////////////////////
////////////////////////////////
////////////////////////////////
=== function Add_Item(ItemName,ItemQty)
{
////////////////////////////////
-   ItemName == List__Items.不明生物的尸体:
    ~   Count__不明生物的尸体 += ItemQty
    {
    -   Count__不明生物的尸体 > 0:
        ~   List__Items += 不明生物的尸体
    }
////////////////////////////////
-   ItemName == List__Items.枯树的碎片:
    ~   Count__枯树的碎片 += ItemQty
    {
    -   Count__枯树的碎片 > 0:
        ~   List__Items += 枯树的碎片
    }
////////////////////////////////
}
////////////////////////////////
////////////////////////////////
////////////////////////////////
////////////////////////////////
////////////////////////////////
////////////////////////////////
=== function Remove_Item(ItemName,ItemQty)
{
////////////////////////////////
-   ItemName == List__Items.不明生物的尸体:
    ~   Count__不明生物的尸体 -= ItemQty
    {
    -   Count__不明生物的尸体 <= 0:
        ~   List__Items -= 不明生物的尸体
    }
////////////////////////////////
-   ItemName == List__Items.枯树的碎片:
    ~   Count__枯树的碎片 -= ItemQty
    {
    -   Count__枯树的碎片 <= 0:
        ~   List__Items -= 枯树的碎片
    }
////////////////////////////////
}
